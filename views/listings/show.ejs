<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-8 offset-2">
    <h3 class="mb-3"><%= listing.title %></h3>

    <div class="card shadow-sm border-0">
      
      <img
        src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e' %>"
        class="card-img-top"
        style="height: 300px; object-fit: cover"
      />

      <div class="card-body">
        <i>Posted by: <%= listing.owner.username %></i>

        <p class="text-muted mt-2">
          <%= listing.description || "No description available" %>
        </p>

        <ul class="list-group list-group-flush mt-3">
          <li class="list-group-item">
            <b>Price:</b> ₹<%= listing.price %>
          </li>
          <li class="list-group-item">
            <b>Location:</b> <%= listing.location %>
          </li>
          <li class="list-group-item">
            <b>Country:</b> <%= listing.country %>
          </li>
        </ul>

        <!-- 🔐 OWNER ACTIONS -->
        <% if (currUser && listing.owner && listing.owner._id.toString() === currUser._id.toString()) { %>
          <div class="mt-4 d-flex gap-2">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">
              Edit
            </a>

            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
              <button class="btn btn-danger">Delete</button>
            </form>
          </div>
        <% } %>

        <hr />

        <!-- 📝 REVIEW FORM -->
        <% if (currUser) { %>
          <div class="mt-4">
            <h4>Leave a Review</h4>

            <form action="/listings/<%= listing._id %>/reviews" method="POST">
              
              <div class="mb-3">
                <label class="form-label">Rating</label>
                <input
                  type="range"
                  name="review[rating]"
                  min="1"
                  max="5"
                  class="form-range"
                >
              </div>

              <div class="mb-3">
                <label class="form-label">Comment</label>
                <textarea
                  name="review[comment]"
                  class="form-control"
                  rows="3"
                  required
                ></textarea>
              </div>

              <button class="btn btn-dark">Submit</button>
            </form>
          </div>
        <% } else { %>
          <p class="text-muted mt-3">Please login to add a review.</p>
        <% } %>

        <hr />

        <!-- ⭐ REVIEWS -->
        <h4>All Reviews</h4>

        <% if (listing.reviews.length === 0) { %>
          <p>No reviews yet</p>
        <% } %>

        <div class="row">
          <% listing.reviews.forEach(review => { %>

            <div class="col-md-6 mb-3">
              <div class="card shadow-sm">
                <div class="card-body">
                  <h1>@<%=review.author.username%></h1>

                  <!-- ⭐ RATING -->
                  <div class="text-warning mb-2">
                    <% for(let i = 1; i <= 5; i++) { %>
                      <% if(i <= review.rating) { %> ⭐ <% } else { %> ☆ <% } %>
                    <% } %>
                  </div>

                  <!-- 💬 COMMENT -->
                  <p class="text-muted"><%= review.comment %></p>

                  <!-- 📅 DATE -->
                  <small>
                    <%= new Date(review.createdAt).toDateString() %>
                  </small>

                  <!-- 🔐 DELETE REVIEW (ONLY OWNER) -->
                  <% if (currUser && review.author && review.author._id.toString() === currUser._id.toString()) { %>
                    <form
                      action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                      method="POST"
                      class="mt-3"
                    >
                      <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                  <% } %>

                </div>  
              </div>
            </div>

          <% }) %>
        </div>

      </div>
    </div>
  </div>
</div>